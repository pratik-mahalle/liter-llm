<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>

    <PackageId>LiterLm</PackageId>
    <Version>0.1.0</Version>
    <Authors>kreuzberg.dev</Authors>
    <Company>kreuzberg.dev</Company>
    <Description>High-performance LLM client for .NET powered by Rust. Unified interface for streaming completions, tool calling, and provider routing across OpenAI, Anthropic, and 50+ LLM providers.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/kreuzberg-dev/liter-lm</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kreuzberg-dev/liter-lm</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>liter-lm;llm;openai;anthropic;streaming;tool-calling;provider-routing;rust;ffi;dotnet</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Version 0.1.0</PackageReleaseNotes>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="/" Condition="Exists('../README.md')" />
    <None Include="runtimes/**" Pack="true" PackagePath="runtimes/" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
