{
	"name": "kreuzberg/liter-llm",
	"description": "Universal LLM API client for PHP. Unified interface for streaming, tool calling, and provider routing across 142+ providers. Rust-powered.",
	"version": "1.1.0",
	"type": "php-ext",
	"license": "MIT",
	"keywords": [
		"llm",
		"llm-client",
		"openai",
		"anthropic",
		"streaming",
		"tool-calling",
		"provider-routing",
		"rust",
		"performance",
		"php8"
	],
	"homepage": "https://kreuzberg.dev",
	"support": {
		"issues": "https://github.com/kreuzberg-dev/liter-llm/issues",
		"source": "https://github.com/kreuzberg-dev/liter-llm"
	},
	"authors": [
		{
			"name": "Na'aman Hirschfeld",
			"email": "naaman@kreuzberg.dev",
			"role": "creator"
		}
	],
	"require": {
		"php": "^8.2"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.94",
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^11.0"
	},
	"autoload": {
		"psr-4": {
			"LiterLlm\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"LiterLlm\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "vendor/bin/phpunit",
		"phpstan": "vendor/bin/phpstan analyse src --level=max --memory-limit=512M",
		"lint": "@phpstan",
		"format": "vendor/bin/php-cs-fixer fix src",
		"format:check": "vendor/bin/php-cs-fixer fix src --dry-run"
	},
	"config": {
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
