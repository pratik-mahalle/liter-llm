# frozen_string_literal: true

# Steep configuration for the LiterLm Ruby package.

target :lib do
  signature 'sig'

  check 'lib'

  # Standard library used by the wrapper layer.
  library 'json'

  # Strategic ignores:

  # 1. Native extension entry point — methods are defined in Rust via Magnus
  #    and cannot be resolved by Steep's static analysis.
  ignore 'lib/liter_lm_rb.rb' if File.exist?('lib/liter_lm_rb.rb')
end
