{
	"name": "@kreuzberg/liter-llm",
	"version": "1.0.0-rc.2",
	"description": "Universal LLM API client \u2014 unified interface for streaming, tool calling, and provider routing across 142+ providers. Rust-powered.",
	"keywords": [
		"llm",
		"llm-client",
		"openai",
		"anthropic",
		"streaming",
		"tool-calling",
		"provider-routing",
		"async",
		"rust"
	],
	"author": {
		"name": "Na'aman Hirschfeld",
		"email": "naaman@kreuzberg.dev",
		"url": "https://github.com/kreuzberg-dev/liter-llm"
	},
	"homepage": "https://kreuzberg.dev",
	"bugs": {
		"url": "https://github.com/kreuzberg-dev/liter-llm/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kreuzberg-dev/liter-llm.git"
	},
	"license": "MIT",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">= 22"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"format": [
			"cjs",
			"esm"
		],
		"dts": true,
		"clean": true
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"lint": "biome check src",
		"lint:fix": "biome check --write src"
	},
	"dependencies": {
		"@kreuzberg/liter-llm-native": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	}
}
