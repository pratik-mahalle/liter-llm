{
	"id": "local_provider_ollama",
	"category": "configuration",
	"description": "Ollama local provider routes requests via ollama/ model prefix with no auth",
	"api": {
		"method": "chat",
		"request": {
			"model": "ollama/qwen2:0.5b",
			"messages": [
				{
					"role": "user",
					"content": "Hello"
				}
			]
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-ollama-001",
				"object": "chat.completion",
				"created": 1711000000,
				"model": "qwen2:0.5b",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": "Hello! How can I help you today?"
						},
						"finish_reason": "stop"
					}
				],
				"usage": {
					"prompt_tokens": 5,
					"completion_tokens": 8,
					"total_tokens": 13
				}
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"choices_count": 1,
		"first_choice_content": "Hello! How can I help you today?",
		"first_choice_finish_reason": "stop",
		"model": "qwen2:0.5b"
	},
	"tags": ["configuration", "local", "ollama"]
}
