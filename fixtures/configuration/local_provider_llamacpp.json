{
	"id": "local_provider_llamacpp",
	"category": "configuration",
	"description": "llamacpp local provider routes requests via llamacpp/ model prefix with no auth",
	"api": {
		"method": "chat",
		"request": {
			"model": "llamacpp/my-model",
			"messages": [
				{
					"role": "user",
					"content": "Hello"
				}
			]
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-llamacpp-001",
				"object": "chat.completion",
				"created": 1711000000,
				"model": "my-model",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": "Hi there! I'm running locally."
						},
						"finish_reason": "stop"
					}
				],
				"usage": {
					"prompt_tokens": 5,
					"completion_tokens": 6,
					"total_tokens": 11
				}
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"choices_count": 1,
		"first_choice_content": "Hi there! I'm running locally.",
		"first_choice_finish_reason": "stop",
		"model": "my-model"
	},
	"tags": ["configuration", "local", "llamacpp"]
}
