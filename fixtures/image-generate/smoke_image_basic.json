{
	"id": "smoke_image_basic",
	"category": "image-generate",
	"description": "Basic image generation with a text prompt",
	"api": {
		"method": "image_generate",
		"request": {
			"model": "dall-e-3",
			"prompt": "A white cat sitting on a windowsill",
			"n": 1,
			"size": "1024x1024"
		},
		"mock_response": {
			"status": 200,
			"body": {
				"created": 1711000000,
				"data": [
					{
						"url": "https://example.com/images/img-abc123.png",
						"revised_prompt": "A fluffy white cat sitting peacefully on a sunlit windowsill"
					}
				]
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"image_count": 1,
		"image_has_url": true
	},
	"tags": ["smoke", "image"],
	"skip": {}
}
