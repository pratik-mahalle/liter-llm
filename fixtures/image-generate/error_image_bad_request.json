{
	"id": "error_image_bad_request",
	"category": "image-generate",
	"description": "400 Bad Request when image generation parameters are invalid",
	"api": {
		"method": "image_generate",
		"request": {
			"model": "dall-e-3",
			"prompt": "A cat",
			"n": 1,
			"size": "9999x9999"
		},
		"mock_response": {
			"status": 400,
			"body": {
				"error": {
					"message": "Invalid value for 'size': '9999x9999'. Supported values are: '1024x1024', '1792x1024', '1024x1792'.",
					"type": "invalid_request_error",
					"param": "size",
					"code": null
				}
			}
		}
	},
	"assertions": {
		"expect_success": false,
		"error_type": "InvalidRequest",
		"error_status_code": 400
	},
	"tags": ["error-handling", "image"],
	"skip": {}
}
