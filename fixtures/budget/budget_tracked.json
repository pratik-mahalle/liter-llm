{
  "id": "budget_tracked",
  "category": "budget",
  "description": "Tests that cost is tracked after a successful response",
  "api": {
    "method": "chat",
    "request": {
      "model": "gpt-4",
      "messages": [
        {
          "role": "user",
          "content": "Hello"
        }
      ]
    },
    "mock_response": {
      "status": 200,
      "body": {
        "id": "chatcmpl-budget-tracked-001",
        "object": "chat.completion",
        "created": 1711000000,
        "model": "gpt-4",
        "choices": [
          {
            "index": 0,
            "message": {
              "role": "assistant",
              "content": "Hello! How can I help you today?"
            },
            "finish_reason": "stop"
          }
        ],
        "usage": {
          "prompt_tokens": 8,
          "completion_tokens": 9,
          "total_tokens": 17
        }
      }
    }
  },
  "assertions": {
    "expect_success": true,
    "cost_tracked": true
  },
  "tags": [
    "budget"
  ],
  "skip": {
    "languages": [
      "wasm"
    ]
  }
}
