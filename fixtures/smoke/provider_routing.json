{
	"id": "smoke_provider_routing",
	"description": "Test provider routing by sending requests to OpenAI and Anthropic",
	"category": "smoke",
	"tags": [
		"smoke",
		"openai",
		"anthropic",
		"routing"
	],
	"call": "chat",
	"input": {
		"model": "openai/gpt-4o-mini",
		"messages": [
			{
				"role": "user",
				"content": "Say hi."
			}
		],
		"max_tokens": 5
	},
	"env": {
		"api_key_var": "OPENAI_API_KEY"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "not_error"
		},
		{
			"type": "not_empty",
			"field": "choices"
		},
		{
			"type": "not_error"
		}
	]
}
