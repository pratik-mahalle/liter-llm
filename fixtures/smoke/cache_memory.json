{
	"id": "smoke_cache_memory",
	"description": "Test in-memory caching by sending identical requests twice",
	"category": "smoke",
	"tags": [
		"smoke",
		"openai",
		"cache"
	],
	"call": "chat",
	"input": {
		"model": "openai/gpt-4o-mini",
		"messages": [
			{
				"role": "user",
				"content": "What is 2+2? Answer with just the number."
			}
		],
		"max_tokens": 5
	},
	"env": {
		"api_key_var": "OPENAI_API_KEY"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "not_error"
		},
		{
			"type": "not_empty",
			"field": "choices"
		},
		{
			"type": "not_error"
		}
	]
}
