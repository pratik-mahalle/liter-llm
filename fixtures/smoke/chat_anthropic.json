{
	"id": "smoke_chat_anthropic",
	"description": "Basic chat completion against real Anthropic API",
	"category": "smoke",
	"tags": ["smoke", "anthropic", "chat"],
	"call": "chat",
	"input": {
		"model": "anthropic/claude-sonnet-4-20250514",
		"messages": [
			{
				"role": "user",
				"content": "Say hello in exactly one word."
			}
		],
		"max_tokens": 10
	},
	"env": {
		"api_key_var": "ANTHROPIC_API_KEY"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "not_error"
		},
		{
			"type": "not_empty",
			"field": "choices"
		},
		{
			"type": "not_empty",
			"field": "usage"
		}
	]
}
