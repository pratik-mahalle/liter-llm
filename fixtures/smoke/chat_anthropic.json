{
	"id": "smoke_chat_anthropic",
	"category": "smoke",
	"description": "Basic chat completion against real Anthropic API",
	"api": {
		"method": "chat",
		"request": {
			"model": "anthropic/claude-sonnet-4-20250514",
			"messages": [{ "role": "user", "content": "Say hello in exactly one word." }],
			"max_tokens": 10
		}
	},
	"assertions": {
		"status": "success",
		"response_not_null": true,
		"has_choices": true,
		"has_usage": true
	},
	"env": {
		"api_key_var": "ANTHROPIC_API_KEY"
	},
	"tags": ["smoke", "anthropic", "chat"]
}
