{
	"id": "smoke_chat_gemini",
	"category": "smoke",
	"description": "Basic chat completion against real Google Gemini API",
	"api": {
		"method": "chat",
		"request": {
			"model": "gemini/gemini-2.5-flash-preview-05-20",
			"messages": [{ "role": "user", "content": "Say hello in exactly one word." }],
			"max_tokens": 10
		}
	},
	"assertions": {
		"status": "success",
		"response_not_null": true,
		"has_choices": true,
		"has_usage": true
	},
	"env": {
		"api_key_var": "GEMINI_API_KEY"
	},
	"tags": ["smoke", "gemini", "chat"]
}
