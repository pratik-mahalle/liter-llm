{
	"id": "local_stream_ollama",
	"category": "streaming",
	"description": "Streaming chat completion via Ollama local provider with SSE chunks",
	"api": {
		"method": "chat_stream",
		"request": {
			"model": "ollama/qwen2:0.5b",
			"messages": [
				{
					"role": "user",
					"content": "Count to 3"
				}
			],
			"stream": true
		},
		"mock_response": {
			"status": 200,
			"stream_chunks": [
				{
					"id": "chatcmpl-ollama-s1",
					"object": "chat.completion.chunk",
					"created": 1711000000,
					"model": "qwen2:0.5b",
					"choices": [{ "index": 0, "delta": { "role": "assistant", "content": "" }, "finish_reason": null }]
				},
				{
					"id": "chatcmpl-ollama-s1",
					"object": "chat.completion.chunk",
					"created": 1711000000,
					"model": "qwen2:0.5b",
					"choices": [{ "index": 0, "delta": { "content": "1 " }, "finish_reason": null }]
				},
				{
					"id": "chatcmpl-ollama-s1",
					"object": "chat.completion.chunk",
					"created": 1711000000,
					"model": "qwen2:0.5b",
					"choices": [{ "index": 0, "delta": { "content": "2 " }, "finish_reason": null }]
				},
				{
					"id": "chatcmpl-ollama-s1",
					"object": "chat.completion.chunk",
					"created": 1711000000,
					"model": "qwen2:0.5b",
					"choices": [{ "index": 0, "delta": { "content": "3" }, "finish_reason": null }]
				},
				{
					"id": "chatcmpl-ollama-s1",
					"object": "chat.completion.chunk",
					"created": 1711000000,
					"model": "qwen2:0.5b",
					"choices": [{ "index": 0, "delta": {}, "finish_reason": "stop" }]
				}
			]
		}
	},
	"assertions": {
		"response_not_null": true,
		"stream_chunk_count_min": 3,
		"stream_final_content": "1 2 3",
		"stream_completes_cleanly": true
	},
	"tags": ["streaming", "local", "ollama"]
}
